NOTION_CLIENT_ID=your-notion-oauth-client-id
NOTION_CLIENT_SECRET=your-notion-oauth-client-secret
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
PORT=3000

# Shared HMAC secret between the pinkha iOS app and this proxy. Must match
# `NotionOAuth2.proxyHmacSecret` in the Swift app. Generate with:
#   openssl rand -hex 32
PROXY_HMAC_SECRET=replace-with-32-bytes-of-random-hex

# Comma-separated list of allowed CORS origins. Leave empty for native-only
# (iOS) clients. Example: https://app.pinkha.io,https://pinkha.io
ALLOWED_ORIGINS=
